# Copy to .env and adapt per machine.
#
# Diego laptop:
#   MAIN_MOUNT_VOLUME=/home/diego/Documents/02-Universidad/Cirtesu
#   DEPTH_ANYTHING_3_CONTEXT=/home/diego/Documents/02-Universidad/Cirtesu/Repositories/Depth-Anything-3
#   CONTAINER_USER=diego
#   CONTAINER_UID=1000
#   CONTAINER_GID=1000
#
# Cirtesu GPU workstation:
#   MAIN_MOUNT_VOLUME=/home/usuario/depth_anything_ws
#   DEPTH_ANYTHING_3_CONTEXT=/home/usuario/depth_anything_ws/src/Depth-Anything-3
#   CONTAINER_USER=usuario
#   CONTAINER_UID=1000
#   CONTAINER_GID=1000

# HOST AND CONTAINER PATHS
MAIN_MOUNT_VOLUME=/home/usuario/depth_anything_ws
CONTAINER_WORKSPACE=/home/usuario/DockerWorkspace

# LOCAL DA3 FOLDER in HOST
DEPTH_ANYTHING_3_CONTEXT=/home/usuario/depth_anything_ws/src/Depth-Anything-3

# CONTAINER USER
CONTAINER_USER=usuario
CONTAINER_UID=1000
CONTAINER_GID=1000

# WRAPPER ROS 2 SOURCE
# WRAPPER_REPO_URL=https://github.com/diegomarzaa/GerdsenAI-Depth-Anything-3-ROS2-Wrapper.git
# WRAPPER_REPO_REF=main
